@startuml Travel Advisor Website - Class Diagram

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam backgroundColor white

abstract class Account {
    +int id
    +String email
    +String password
    +login()
    +logout()
}

class User {
    +String firstName
    +String lastName
    +register()
}

class Admin {
    +manageUsers()
    +manageBookings()
}

class Destination {
    +int id
    +String name
    +String country
    +String description
    +String[] images
    +float rating
    +float cost
}

class TopPlace {
    +int id
    +String name
    +String description
}

class Flight {
    +int id
    +String airlineName
    +String departureCity
    +String arrivalCity
    +DateTime departureTime
    +DateTime arrivalTime
    +float price
    +int durationMinutes
}

class Booking {
    +int id
    +Date bookingDate
    +String status
}

class Passenger {
    +int id
    +String fullName
    +String passportNumber
    +Date dateOfBirth
}

class Payment {
    +int id
    +String cardNumber
    +String cardholderName
    +String expiryDate
    +String cvv
    +String status
    +processPayment()
}

class Review {
    +int id
    +String comment
    +float rating
    +DateTime submittedAt
}

' Inheritance from abstract base
User --|> Account : extends
Admin --|> Account : extends

' Composition
Destination "1" *-- "1..*" TopPlace : contains
Booking "1" *-- "1" Passenger : carries
Booking "1" *-- "1" Payment : paid via

' Admin dependencies 
Admin ..> User : manages
Admin ..> Booking : manages

' Associations
User "1" --> "0..*" Booking : makes
Booking "1" --> "1" Flight : reserves
Flight "1" --> "1" Destination : flies to
User "1" --> "0..*" Review : writes

@enduml
